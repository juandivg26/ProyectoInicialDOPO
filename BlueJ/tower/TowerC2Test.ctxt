#BlueJ class context
comment0.target=TowerC2Test
comment0.text=\r\n\ Casos\ de\ prueba\ de\ unidad\ para\ la\ clase\ Tower\ -\ Ciclo\ 2.\r\n\ Todas\ las\ pruebas\ se\ ejecutan\ en\ modo\ invisible.\r\n\r\n\ @author\ Juan\ Diego\ Valderrama\ Gaviria\ y\ Jhonatan\ Madero\r\n\ @version\ 2.0\r\n
comment1.params=
comment1.target=void\ shouldCreateTowerWithCupsAndCorrectHeight()
comment1.text=\r\n\ Crear\ una\ torre\ con\ 4\ tazas\ debe\ generar\ tazas\ de\ alturas\ 1,\ 3,\ 5,\ 7.\r\n\ La\ altura\ total\ debe\ ser\ 1+3+5+7\ \=\ 16.\r\n
comment10.params=
comment10.target=void\ shouldNotSwapNonExistentItem()
comment10.text=\r\n\ Intercambiar\ un\ objeto\ que\ no\ existe\ en\ la\ torre\ no\ debe\ ser\ v\u00E1lido.\r\n
comment11.params=
comment11.target=void\ shouldNotSwapWithNullParameters()
comment11.text=\r\n\ Intercambiar\ con\ par\u00E1metros\ nulos\ no\ debe\ ser\ v\u00E1lido.\r\n
comment12.params=
comment12.target=void\ shouldNotSwapWithInvalidNumber()
comment12.text=\r\n\ Intercambiar\ con\ n\u00FAmero\ inv\u00E1lido\ (no\ num\u00E9rico)\ no\ debe\ ser\ v\u00E1lido.\r\n
comment13.params=
comment13.target=void\ shouldCoverCupsWithMatchingLids()
comment13.text=\r\n\ cover()\ debe\ mover\ la\ tapa\ justo\ encima\ de\ su\ taza\ correspondiente.\r\n
comment14.params=
comment14.target=void\ shouldNotFailCoverWithNoLids()
comment14.text=\r\n\ cover()\ sobre\ una\ torre\ sin\ tapas\ no\ debe\ cambiar\ nada\ ni\ lanzar\ error.\r\n
comment15.params=
comment15.target=void\ shouldNotMoveLidAlreadyOnItsCup()
comment15.text=\r\n\ Una\ taza\ ya\ tapada\ no\ debe\ ser\ movida\ de\ nuevo\ por\ cover().\r\n
comment16.params=
comment16.target=void\ shouldNotCoverLidWithoutMatchingCup()
comment16.text=\r\n\ Tapa\ sin\ taza\ correspondiente\ en\ la\ torre\ no\ debe\ moverse\ con\ cover().\r\n
comment17.params=
comment17.target=void\ shouldReturnSwapThatReducesHeight()
comment17.text=\r\n\ swapToReduce\ debe\ retornar\ un\ intercambio\ que\ efectivamente\ reduce\ la\ altura.\r\n
comment18.params=
comment18.target=void\ shouldReturnEmptyWhenNoSwapReducesHeight()
comment18.text=\r\n\ Si\ la\ torre\ ya\ est\u00E1\ en\ su\ configuraci\u00F3n\ de\ menor\ altura\ posible,\r\n\ swapToReduce\ debe\ retornar\ un\ arreglo\ vac\u00EDo.\r\n
comment19.params=
comment19.target=void\ shouldReturnEmptySwapOnEmptyTower()
comment19.text=\r\n\ swapToReduce\ sobre\ torre\ vac\u00EDa\ debe\ retornar\ arreglo\ vac\u00EDo\ sin\ error.\r\n
comment2.params=
comment2.target=void\ shouldCreateTowerWithOneCup()
comment2.text=\r\n\ Crear\ una\ torre\ con\ 1\ taza\ debe\ tener\ altura\ 1\ (2*1-1\ \=\ 1).\r\n
comment20.params=
comment20.target=void\ shouldReturnEmptySwapWithSingleElement()
comment20.text=\r\n\ swapToReduce\ sobre\ torre\ con\ un\ solo\ elemento\ debe\ retornar\ vac\u00EDo.\r\n
comment21.params=
comment21.target=void\ shouldReturnLidedCupsInAscendingOrder()
comment21.text=\r\n\ lidedCups\ debe\ retornar\ los\ n\u00FAmeros\ de\ las\ tazas\ tapadas\ en\ orden\ ascendente.\r\n
comment22.params=
comment22.target=void\ shouldReturnEmptyLidedCupsWhenNoneAreCovered()
comment22.text=\r\n\ lidedCups\ debe\ retornar\ arreglo\ vac\u00EDo\ si\ no\ hay\ ninguna\ taza\ tapada.\r\n
comment23.params=
comment23.target=void\ shouldNotCountLidNotDirectlyOnCupAsLided()
comment23.text=\r\n\ Una\ tapa\ que\ no\ est\u00E1\ justo\ sobre\ su\ taza\ no\ debe\ contar\ como\ tapada.\r\n
comment3.params=
comment3.target=void\ shouldNotCreateTowerWithZeroCups()
comment3.text=\r\n\ Crear\ una\ torre\ con\ 0\ tazas\ no\ debe\ ser\ v\u00E1lido\ (ok()\ \=\ false).\r\n
comment4.params=
comment4.target=void\ shouldNotCreateTowerWithNegativeCups()
comment4.text=\r\n\ Crear\ una\ torre\ con\ n\u00FAmero\ negativo\ de\ tazas\ no\ debe\ ser\ v\u00E1lido.\r\n
comment5.params=
comment5.target=void\ shouldCreateTowerWithOnlyCupsNoLids()
comment5.text=\r\n\ La\ torre\ creada\ con\ cups\ no\ debe\ tener\ tapas\ (stackingItems\ solo\ tazas).\r\n
comment6.params=
comment6.target=void\ shouldCreateTowerWithExactNumberOfCups()
comment6.text=\r\n\ Torre\ con\ 3\ tazas\ debe\ tener\ exactamente\ 3\ items.\r\n
comment7.params=
comment7.target=void\ shouldSwapTwoCupsSuccessfully()
comment7.text=\r\n\ Intercambiar\ taza\ 1\ con\ taza\ 2\ debe\ cambiar\ sus\ posiciones\ en\ la\ torre.\r\n
comment8.params=
comment8.target=void\ shouldSwapCupWithLid()
comment8.text=\r\n\ Intercambiar\ una\ taza\ con\ una\ tapa\ debe\ funcionar\ correctamente.\r\n
comment9.params=
comment9.target=void\ shouldNotSwapItemWithItself()
comment9.text=\r\n\ Intercambiar\ un\ objeto\ consigo\ mismo\ no\ debe\ ser\ v\u00E1lido.\r\n
numComments=24
