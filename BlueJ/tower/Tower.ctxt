comment2.target=Tower(int)
comment2.text=\r\n\ Crea\ una\ torre\ con\ las\ tazas\ de\ 1\ a\ cups.\r\n\ El\ ancho\ es\ cups\ y\ el\ alto\ es\ la\ suma\ de\ las\ alturas.\r\n\ @param\ cups\ numero\ de\ tazas\ a\ crear\r\n
