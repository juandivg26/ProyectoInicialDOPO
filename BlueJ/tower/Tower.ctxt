comment17.target=int[]\ lidedCups()
comment17.text=\r\n\ Retorna\ los\ numeros\ de\ las\ tazas\ tapadas.\r\n\ Una\ taza\ esta\ tapada\ si\ su\ tapa\ esta\ justo\ encima.\r\n\ @return\ array\ con\ los\ numeros\ de\ las\ tazas\ tapadas\ en\ orden\ ascendente\r\n
